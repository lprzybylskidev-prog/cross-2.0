{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Listen for Xdebug (cross)",
      "type": "php",
      "request": "launch",
      "port": 9003,
      "hostname": "0.0.0.0",
      "log": false,
      "pathMappings": {
        "/workspace": "${workspaceFolder}"
      },
      "xdebugSettings": {
        "max_children": 128,
        "max_data": 1024,
        "show_hidden": 1
      }
    }
  ]
}
