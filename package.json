{
    "name": "cross-dev-tooling",
    "private": true,
    "version": "1.0.0",
    "description": "Laravel app with devcontainer tooling for cross project",
    "scripts": {
        "format": "bash scripts/format.sh",
        "format:check": "npx prettier --check --ignore-unknown app bootstrap config database docs lang resources routes scripts src tests .env.example README.md composer.json package.json vite.config.js vitest.config.ts playwright.config.ts phpstan.neon.dist .prettierrc.json .prettierignore",
        "test": "npm run test:unit",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "dev": "vite",
        "build": "vite build"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0",
        "@playwright/test": "^1.58.2",
        "@prettier/plugin-php": "^0.24.0",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vitest/coverage-v8": "^4.1.0",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.4.16",
        "axios": "^1.13.6",
        "concurrently": "^9.2.1",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^2.1.0",
        "playwright": "^1.58.2",
        "postcss": "^8.4.32",
        "prettier": "^3.8.1",
        "prettier-plugin-blade": "^2.1.21",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0",
        "vue": "^3.3.13"
    },
    "type": "module",
    "dependencies": {
        "@tabler/icons-vue": "^3.40.0",
        "flag-icons": "^7.5.0"
    }
}
